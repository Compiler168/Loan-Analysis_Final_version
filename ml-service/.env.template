# SmartLoan AI+ ML Service Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8000
HOST=0.0.0.0
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Model Configuration
MODEL_PATH=./models
DATA_PATH=./data
BATCH_SIZE=32
NUM_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGINS=*

# ML Model Settings
PREDICTION_CONFIDENCE_THRESHOLD=0.5
USE_ENSEMBLE=true
ENSEMBLE_MODELS=xgboost,random_forest,logistic_regression

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CACHE_TTL=3600

# Monitoring & Logging (Optional)
# SENTRY_DSN=https://key@sentry.io/project
# PROMETHEUS_METRICS=true

# Database (Optional - if logging predictions)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartloan
# LOG_PREDICTIONS=true
