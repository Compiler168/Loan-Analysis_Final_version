<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prediction_title"
                style="@style/TextStyle.Heading1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/prediction_subtitle"
                style="@style/TextStyle.Caption"
                android:textSize="14sp" />

        <!-- Step Indicator -->
        <LinearLayout android:id="@+id/stepIndicator" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center" android:orientation="horizontal" />

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_radius" app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_background" app:strokeWidth="1dp" app:strokeColor="@color/card_stroke">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="@dimen/card_padding">

                <TextView android:id="@+id/tvStepTitle" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" style="@style/TextStyle.Heading3" />

                <!-- Step 1: Personal Info -->
                <LinearLayout android:id="@+id/step1" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_md">
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="@string/age" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAge"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="35" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/dependents" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDependents"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/employment_status" style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                        <AutoCompleteTextView android:id="@+id/spinnerEmployment"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="none" android:text="salaried" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/employment_years" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEmploymentYears"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="5" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Step 2: Financial Details -->
                <LinearLayout android:id="@+id/step2" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:visibility="gone" android:layout_marginTop="@dimen/spacing_md">
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="@string/monthly_income" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etIncome"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="7500" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/monthly_expenses" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etExpenses"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="3000" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/credit_score_label" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etCreditScore"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="720" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/existing_loans" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etExistingLoans"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/existing_emi" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etExistingEmi"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="500" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/savings_balance" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSavings"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="25000" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Step 3: Loan Parameters -->
                <LinearLayout android:id="@+id/step3" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:visibility="gone" android:layout_marginTop="@dimen/spacing_md">
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="@string/loan_amount" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLoanAmount"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="50000" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/loan_term" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLoanTerm"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="36" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/interest_rate" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etInterestRate"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="10" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/property_value" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPropertyValue"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal" android:text="150000" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/missed_payments" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMissedPayments"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="0" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="@string/bankruptcies" style="@style/Widget.SmartLoan.TextInput">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankruptcies"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="number" android:text="0" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Navigation Buttons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md" android:gravity="center_vertical">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/back" style="@style/Widget.SmartLoan.Button.Outline"
                        android:visibility="gone" />
                    <View android:layout_width="@dimen/spacing_sm" android:layout_height="1dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnNext"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/next" />
                </LinearLayout>

                <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center"
                    android:layout_marginTop="@dimen/spacing_sm" android:visibility="gone"
                    android:indeterminateTint="@color/primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Results Section -->
        <LinearLayout android:id="@+id/resultsContainer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_lg" android:visibility="gone">

            <!-- Premium Result Header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_prediction_result_header"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Analysis Result"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentRight="true"
                            android:src="@drawable/ic_ai_sparkle"
                            app:tint="#FFFFFF" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp">
                            <ProgressBar
                                android:id="@+id/progressApproval"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                android:max="100"
                                android:progress="75"
                                android:secondaryProgress="100"
                                android:progressDrawable="@drawable/circular_progress_bar"
                                style="?android:attr/progressBarStyleHorizontal" />

                            <TextView
                                android:id="@+id/tvApprovalPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="75%"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="24dp">

                            <TextView
                                android:id="@+id/tvApprovalStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Approved"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/riskBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_status_chip"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical">
                                <View
                                    android:id="@+id/riskDot"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/bg_circle_gradient"
                                    android:backgroundTint="#10B981" />
                                <TextView
                                    android:id="@+id/tvRiskLevel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LOW RISK"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvConfidence"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Confidence Score: 92%"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:layout_marginTop="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Financial Health Snapshot (Derived Metrics) -->
            <LinearLayout
                android:id="@+id/derivedMetricsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="3"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#050F172A"
                    app:strokeWidth="1dp"
                    app:strokeColor="#0D000000">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DTI RATIO"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvDtiRatio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24%"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#050F172A"
                    app:strokeWidth="1dp"
                    app:strokeColor="#0D000000">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMI LOAD"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvRequestedEmi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$1,200"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#050F172A"
                    app:strokeWidth="1dp"
                    app:strokeColor="#0D000000">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SAVINGS"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvSavingsRatio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15%"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveResult"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save Result"
                    app:icon="@drawable/ic_nav_reports"
                    style="@style/Widget.SmartLoan.Button.Outline" />
                <View android:layout_width="12dp" android:layout_height="1dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadReport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Report"
                    app:icon="@drawable/ic_chevron_right"
                    style="@style/Widget.SmartLoan.Button" />
            </LinearLayout>

            <!-- Insight Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detailed Insights"
                style="@style/TextStyle.Heading3"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp" />

            <!-- Model Breakdown (Neural Network Variance) -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp"
                app:cardCornerRadius="@dimen/card_radius" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background" app:strokeWidth="1dp" app:strokeColor="@color/card_stroke">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/card_padding">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Neural Network Variance" style="@style/TextStyle.Caption"
                        android:textColor="@color/primary" android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:scrollbars="none">
                        <LinearLayout android:id="@+id/modelsContainer" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:orientation="horizontal"
                            android:paddingBottom="8dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Key Decision Drivers -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background" app:strokeWidth="1dp" app:strokeColor="@color/card_stroke">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/card_padding">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Key Decision Drivers" style="@style/TextStyle.Caption"
                        android:textColor="@color/primary" android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/insightCardsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Risk Factors -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="@dimen/card_radius" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background" app:strokeWidth="1dp" app:strokeColor="@color/card_stroke">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/card_padding">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Risk Identification" style="@style/TextStyle.Caption"
                        android:textColor="@color/primary" android:textStyle="bold" />
                    <LinearLayout android:id="@+id/riskContainer" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_sm" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recalculate Prediction"
                style="@style/Widget.SmartLoan.Button.Outline"
                android:layout_marginBottom="40dp" />
        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout android:id="@+id/emptyState" android:layout_width="match_parent" android:layout_height="300dp"
            android:gravity="center" android:orientation="vertical" android:background="@drawable/bg_dashed_border"
            android:layout_marginTop="@dimen/spacing_md">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🧠" android:textSize="40sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/run_prediction" style="@style/TextStyle.Caption" android:textSize="14sp"
                android:layout_marginTop="@dimen/spacing_sm" />
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</FrameLayout>
